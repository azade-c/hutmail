<% breadcrumbs ["Bateaux", vessels_path], [@vessel.name, vessel_path(@vessel)], ["Dépêches"] %>

<div class="page-header">
  <h1>Dépêches</h1>
  <%= button_to "Envoyer maintenant", vessel_dispatch_path(@vessel), class: "btn",
      disabled: !@vessel.dispatchable_messages?,
      data: { turbo_confirm: "Collecter et envoyer la dépêche maintenant ?" } %>
</div>

<% if @bundles.any? %>
  <% @bundles.each do |bundle| %>
    <div class="card">
      <a href="<%= bundle_path(bundle) %>">
        <div class="flex align-center justify-space-between">
          <span class="<%= class_names("badge", "badge--#{bundle.status}") %>"><%= bundle.status %></span>
          <span class="txt-small">
            <%= bundle.messages_count %> messages ·
            <%= Bundle.format_size(bundle.dispatch_size || 0) %>
          </span>
        </div>
        <div class="txt-x-small txt-subtle margin-block-start-half">
          <% if bundle.sent_at %>
            Envoyé le <%= bundle.sent_at.strftime("%d %b %Y %H:%M") %>
          <% else %>
            Créé le <%= bundle.created_at.strftime("%d %b %Y %H:%M") %>
          <% end %>
        </div>
        <% if bundle.remaining_count.to_i > 0 %>
          <div class="txt-x-small txt-subtle">
            + <%= bundle.remaining_count %> dans le screener
          </div>
        <% end %>
      </a>
    </div>
  <% end %>
<% else %>
  <div class="empty-state">Aucune dépêche pour l'instant.</div>
<% end %>
