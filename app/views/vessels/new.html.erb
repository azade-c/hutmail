<h1>Set up your vessel</h1>
<p>Before you can use HutMail, register your boat and its relay account.</p>

<%= form_with(model: @vessel, url: vessels_path) do |f| %>
  <% if @vessel.errors.any? %>
    <div class="card card--error">
      <div class="card__header txt-negative">Errors</div>
      <ul>
        <% @vessel.errors.full_messages.each do |msg| %>
          <li class="txt-small"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card">
    <h2 class="card__header">Vessel</h2>
    <div class="form-group">
      <label>Vessel name</label>
      <%= f.text_field :name, class: "input", placeholder: "e.g. Alibi", autofocus: true %>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Callsign</label>
        <%= f.text_field :callsign, class: "input", placeholder: "e.g. FG1234" %>
      </div>
      <div class="form-group">
        <label>SailMail address</label>
        <%= f.text_field :sailmail_address, class: "input", placeholder: "CALLSIGN@sailmail.com" %>
      </div>
    </div>
  </div>

  <%= f.fields_for :relay_account do |ra| %>
    <div class="card">
      <h2 class="card__header">Relay account (IMAP)</h2>
      <p class="txt-small txt-subtle margin-block-end">This account bridges HutMail and the boat.</p>
      <div class="form-row">
        <div class="form-group">
          <label>IMAP server</label>
          <%= ra.text_field :imap_server, class: "input" %>
        </div>
        <div class="form-group">
          <label>Port</label>
          <%= ra.number_field :imap_port, class: "input", value: @vessel.relay_account.imap_port || 993 %>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Username</label>
          <%= ra.text_field :imap_username, class: "input" %>
        </div>
        <div class="form-group">
          <label>Password</label>
          <%= ra.password_field :imap_password, class: "input" %>
        </div>
      </div>
      <div class="form-group">
        <label><%= ra.check_box :imap_use_ssl %> Use SSL</label>
      </div>
    </div>

    <div class="card">
      <h2 class="card__header">Relay account (SMTP)</h2>
      <div class="form-row">
        <div class="form-group">
          <label>SMTP server</label>
          <%= ra.text_field :smtp_server, class: "input" %>
        </div>
        <div class="form-group">
          <label>Port</label>
          <%= ra.number_field :smtp_port, class: "input", value: @vessel.relay_account.smtp_port || 587 %>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Username</label>
          <%= ra.text_field :smtp_username, class: "input" %>
        </div>
        <div class="form-group">
          <label>Password</label>
          <%= ra.password_field :smtp_password, class: "input" %>
        </div>
      </div>
      <div class="form-group">
        <label><%= ra.check_box :smtp_use_starttls %> Use STARTTLS</label>
      </div>
    </div>
  <% end %>

  <div class="form-actions">
    <%= f.submit "Create vessel", class: "btn btn--link" %>
  </div>
<% end %>
