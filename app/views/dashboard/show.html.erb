<div class="page-header">
  <h1>Dashboard</h1>
</div>

<div class="stat-grid">
  <div class="stat">
    <div class="stat__value"><%= @pending_messages.size %></div>
    <div class="stat__label">Pending messages</div>
  </div>
  <div class="stat">
    <div class="stat__value"><%= @mail_accounts.size %></div>
    <div class="stat__label">Mail accounts</div>
  </div>
  <div class="stat">
    <div class="stat__value"><%= Bundle.format_size(@budget_remaining) %></div>
    <div class="stat__label">Budget remaining (7d)</div>
  </div>
  <div class="stat">
    <div class="stat__value"><%= current_vessel.bundle_ratio %>%</div>
    <div class="stat__label">Bundle ratio</div>
  </div>
</div>

<% if @budget_remaining > 0 || @budget_consumed > 0 %>
  <% total = current_vessel.daily_budget_kb * 7 * 1024 %>
  <% pct = total > 0 ? ((@budget_consumed.to_f / total) * 100).clamp(0, 100) : 0 %>
  <div class="card margin-block-end">
    <div class="card__header">Radio budget (7 rolling days)</div>
    <div class="txt-small txt-subtle">
      <%= Bundle.format_size(@budget_consumed) %> used of <%= Bundle.format_size(total) %>
    </div>
    <div class="budget-bar">
      <div class="budget-bar__fill" style="inline-size: <%= pct %>%"></div>
    </div>
  </div>
<% end %>

<div class="card">
  <div class="card__header">Pending messages</div>

  <% if @pending_messages.any? %>
    <ul class="message-list">
      <% @pending_messages.each do |msg| %>
        <li class="message-item">
          <div class="message-item__header">
            <span class="message-item__code"><%= msg.hutmail_id %></span>
            <span class="badge badge--pending">pending</span>
          </div>
          <div>
            <span class="message-item__from"><%= msg.from_name.presence || msg.from_address %></span>
            <span class="message-item__subject">— <%= msg.subject %></span>
          </div>
          <div class="txt-x-small txt-subtle">
            <%= msg.date&.strftime("%d %b %H:%M") %> · <%= Bundle.format_size(msg.stripped_size) %>
            <% if msg.attachments_metadata.present? %>
              · 📎 <%= msg.attachments_metadata.size %> attachment<%= msg.attachments_metadata.size > 1 ? "s" : "" %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="empty-state">No pending messages.</div>
  <% end %>
</div>

<% if @recent_bundles.any? %>
  <div class="card" style="margin-block-start: var(--block-space);">
    <div class="card__header">Recent bundles</div>
    <ul class="message-list">
      <% @recent_bundles.each do |bundle| %>
        <li class="message-item">
          <a href="<%= bundle_path(bundle) %>">
            <span class="badge badge--<%= bundle.status %>"><%= bundle.status %></span>
            <%= bundle.messages_count %> messages
            · <%= Bundle.format_size(bundle.total_stripped_size || 0) %>
            <% if bundle.sent_at %>
              · sent <%= bundle.sent_at.strftime("%d %b %H:%M") %>
            <% end %>
          </a>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
