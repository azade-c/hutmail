<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Commandes Hutmail</title>
  <style>
    :root { color-scheme: light dark }
    body { font: 16px/1.5 system-ui, sans-serif; max-width: 42rem; margin: 0 auto; padding: 1rem }
    h1 { font-size: 1.4rem; margin: 0 0 .2rem }
    h2 { font-size: 1.1rem; margin: 1.6rem 0 .4rem; border-bottom: 1px solid; padding-bottom: .2rem }
    p { margin: .4rem 0 }
    code { font-family: ui-monospace, monospace; background: rgba(127,127,127,.18); padding: .05em .3em; border-radius: .2em }
    pre { font-family: ui-monospace, monospace; background: rgba(127,127,127,.18); padding: .6rem .8rem; border-radius: .3em; overflow-x: auto; white-space: pre-wrap }
    table { border-collapse: collapse; width: 100% }
    td, th { border-bottom: 1px solid rgba(127,127,127,.3); padding: .3rem .4rem; text-align: left; vertical-align: top }
    .muted { color: #777; font-size: .85rem }
  </style>
</head>
<body>
  <%= yield %>
</body>
</html>
