<%= form_with(model: mail_account, url: mail_account.persisted? ? vessel_mail_account_path(mail_account.vessel, mail_account) : vessel_mail_accounts_path(mail_account.vessel)) do |f| %>
  <% if mail_account.errors.any? %>
    <div class="card" style="--border-color: var(--color-negative); margin-block-end: var(--block-space);">
      <div class="card__header txt-negative">Erreurs</div>
      <ul>
        <% mail_account.errors.full_messages.each do |msg| %>
          <li class="txt-small"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-row">
    <div class="form-group">
      <label>Nom du compte</label>
      <%= f.text_field :name, class: "input", placeholder: "Gmail perso" %>
    </div>
    <div class="form-group">
      <label>Code court (2 lettres)</label>
      <%= f.text_field :short_code, class: "input input--short-code", placeholder: "GM", maxlength: 2 %>
    </div>
  </div>

  <%= render "shared/connection_fields", f:,
    imap_title: "Réception (IMAP)",
    smtp_title: "Envoi (SMTP)",
    imap_server_placeholder: "imap.example.com",
    smtp_server_placeholder: "smtp.example.com",
    username_placeholder: "user@example.com" %>

  <h2 class="txt-medium margin-block-start">Options</h2>
  <div class="form-group">
    <label>
      <%= f.check_box :skip_already_read %> Ignorer les messages déjà lus (wifi marina)
    </label>
  </div>
  <div class="form-group">
    <label>
      <%= f.check_box :is_default %> Compte par défaut pour les réponses
    </label>
  </div>

  <div class="form-actions">
    <%= f.submit class: "btn btn--link" %>
    <a href="<%= vessel_mail_accounts_path(mail_account.vessel) %>" class="btn">Annuler</a>
  </div>
<% end %>
