<%= form_with(model: mail_account) do |f| %>
  <% if mail_account.errors.any? %>
    <div class="card" style="--border-color: var(--color-negative); margin-block-end: var(--block-space);">
      <div class="card__header txt-negative">Erreurs</div>
      <ul>
        <% mail_account.errors.full_messages.each do |msg| %>
          <li class="txt-small"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-row">
    <div class="form-group">
      <label>Nom du compte</label>
      <%= f.text_field :name, class: "input", placeholder: "Gmail perso" %>
    </div>
    <div class="form-group">
      <label>Code court (2 lettres)</label>
      <%= f.text_field :short_code, class: "input", placeholder: "GM", maxlength: 2, style: "max-inline-size: 6ch; text-transform: uppercase;" %>
    </div>
  </div>

  <h2 class="txt-medium margin-block-start">Réception (IMAP)</h2>
  <div class="form-row">
    <div class="form-group">
      <label>Serveur IMAP</label>
      <%= f.text_field :imap_server, class: "input", placeholder: "imap.gmail.com" %>
    </div>
    <div class="form-group">
      <label>Port</label>
      <%= f.number_field :imap_port, class: "input", value: mail_account.imap_port || 993 %>
    </div>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label>Identifiant</label>
      <%= f.text_field :imap_username, class: "input", placeholder: "user@gmail.com" %>
    </div>
    <div class="form-group">
      <label>Mot de passe</label>
      <%= f.password_field :imap_password, class: "input" %>
    </div>
  </div>
  <div class="form-group">
    <label>
      <%= f.check_box :imap_use_ssl %> Utiliser SSL
    </label>
  </div>

  <h2 class="txt-medium margin-block-start">Envoi (SMTP)</h2>
  <div class="form-row">
    <div class="form-group">
      <label>Serveur SMTP</label>
      <%= f.text_field :smtp_server, class: "input", placeholder: "smtp.gmail.com" %>
    </div>
    <div class="form-group">
      <label>Port</label>
      <%= f.number_field :smtp_port, class: "input", value: mail_account.smtp_port || 587 %>
    </div>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label>Identifiant</label>
      <%= f.text_field :smtp_username, class: "input", placeholder: "user@gmail.com" %>
    </div>
    <div class="form-group">
      <label>Mot de passe</label>
      <%= f.password_field :smtp_password, class: "input" %>
    </div>
  </div>
  <div class="form-group">
    <label>
      <%= f.check_box :smtp_use_starttls %> Utiliser STARTTLS
    </label>
  </div>

  <h2 class="txt-medium margin-block-start">Options</h2>
  <div class="form-group">
    <label>
      <%= f.check_box :skip_already_read %> Ignorer les messages déjà lus (wifi marina)
    </label>
  </div>
  <div class="form-group">
    <label>
      <%= f.check_box :is_default %> Compte par défaut pour les réponses
    </label>
  </div>

  <div class="form-actions">
    <%= f.submit class: "btn btn--link" %>
    <a href="<%= mail_accounts_path %>" class="btn">Annuler</a>
  </div>
<% end %>
