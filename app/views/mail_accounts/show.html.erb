<% breadcrumb ["Bateaux", vessels_path], [@vessel.name, vessel_path(@vessel)], [@mail_account.name] %>

<div class="page-header">
  <h1>
    <span class="badge"><%= @mail_account.short_code %></span>
    <%= @mail_account.name %>
  </h1>
  <div class="flex gap">
    <%= button_to "Relancer la collecte", mail_account_collection_path(@mail_account),
        method: :post, class: "btn btn--link",
        data: { turbo_confirm: "Relancer la collecte IMAP et réconcilier les messages ?" } %>
    <a href="<%= edit_mail_account_path(@mail_account) %>" class="btn">Modifier</a>
    <%= button_to "Supprimer", mail_account_path(@mail_account), method: :delete,
        class: "btn btn--negative",
        data: { turbo_confirm: "Supprimer ce compte et tous ses messages ?" } %>
  </div>
</div>

<div class="stat-grid">
  <div class="stat">
    <div class="stat__value"><%= @mail_account.message_digests.bundleable.count %></div>
    <div class="stat__label">À dépêcher</div>
  </div>
  <div class="stat">
    <div class="stat__value"><%= @mail_account.message_digests.bundled.count %></div>
    <div class="stat__label">Dépêchés</div>
  </div>
  <div class="stat">
    <div class="stat__value"><%= @mail_account.message_digests.count %></div>
    <div class="stat__label">Total collectés</div>
  </div>
</div>

<div class="card">
  <div class="card__header">Messages récents</div>

  <% if @messages.any? %>
    <ul class="message-list">
      <% @messages.each do |msg| %>
        <li class="message-item">
          <div class="message-item__header">
            <span class="message-item__code"><%= msg.hutmail_reference %></span>
            <span class="badge badge--<%= msg.status %>"><%= msg.status_label %></span>
          </div>
          <div>
            <span class="message-item__from"><%= msg.from_name.presence || msg.from_address %></span>
            <span class="message-item__subject">— <%= msg.subject %></span>
          </div>
          <div class="txt-x-small txt-subtle">
            <%= msg.date&.strftime("%d %b %H:%M") %> · <%= Bundle.format_size(msg.stripped_size || 0) %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="empty-state">Aucun message collecté pour l'instant.</div>
  <% end %>
</div>
