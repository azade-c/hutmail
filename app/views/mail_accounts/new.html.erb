<% content_for(:title, "Add Mail Account — HutMail") %>

<div class="w-full max-w-xl mx-auto">
  <h1 class="text-3xl font-bold mb-8">Add IMAP Account</h1>

  <% if @mail_account.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mb-6">
      <ul class="list-disc list-inside text-sm">
        <% @mail_account.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @mail_account, class: "space-y-5" do |f| %>
    <div>
      <%= f.label :name, "Account Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, placeholder: "e.g. Personal Gmail", class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", required: true %>
      <p class="text-xs text-gray-400 mt-1">A friendly name for this account.</p>
    </div>

    <div>
      <%= f.label :imap_server, "IMAP Server", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :imap_server, placeholder: "imap.gmail.com", class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", required: true %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :imap_port, "Port", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :imap_port, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", required: true %>
      </div>
      <div class="flex items-end pb-2">
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.check_box :use_ssl, class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
          <span class="text-sm text-gray-700">Use SSL/TLS</span>
        </label>
      </div>
    </div>

    <div>
      <%= f.label :imap_username, "Username / Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :imap_username, placeholder: "you@gmail.com", class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", required: true, autocomplete: "off" %>
    </div>

    <div>
      <%= f.label :imap_password, "Password / App Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :imap_password, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", required: true, autocomplete: "off" %>
      <p class="text-xs text-gray-400 mt-1">For Gmail, use an App Password. Stored encrypted.</p>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Test Connection & Save", class: "bg-blue-600 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-blue-700 transition cursor-pointer" %>
      <%= link_to "Cancel", mail_accounts_path, class: "text-gray-500 hover:text-gray-700" %>
    </div>
  <% end %>
</div>
