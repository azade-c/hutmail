<div class="auth">
  <h1 class="auth__title">🦫 HutMail</h1>
  <p class="auth__subtitle">Le facteur des marins hauturiers</p>

  <%= form_with model: @user, url: user_path, class: "auth__form" do |form| %>
    <% if @user.errors.any? %>
      <div class="card card--error">
        <% @user.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <div class="form-group">
      <label for="user_email_address">Email</label>
      <%= form.email_field :email_address, class: "input", required: true, autofocus: true, autocomplete: "email", placeholder: "vous@exemple.com" %>
    </div>

    <div class="form-group" data-controller="password-visibility">
      <label for="user_password">Mot de passe</label>
      <div class="input-with-toggle">
        <%= form.password_field :password, class: "input", required: true, autocomplete: "new-password", placeholder: "12 caractères minimum", maxlength: 72, data: { password_visibility_target: "input" } %>
        <button type="button" class="input-toggle" data-password-visibility-target="toggle" data-action="password-visibility#toggle">Afficher</button>
      </div>
    </div>

    <div class="form-actions">
      <%= form.submit "Créer un compte", class: "btn btn--link auth__submit" %>
    </div>
  <% end %>

  <p class="auth__alt">Déjà un compte ? <%= link_to "Se connecter", new_session_path %></p>
</div>
