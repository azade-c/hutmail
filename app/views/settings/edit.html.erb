<div class="page-header">
  <h1>Réglages</h1>
</div>

<%= form_with(model: @vessel, url: settings_path) do |f| %>
  <% if @vessel.errors.any? %>
    <div class="card card--error">
      <div class="card__header txt-negative">Erreurs</div>
      <ul>
        <% @vessel.errors.full_messages.each do |msg| %>
          <li class="txt-small"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card">
    <h2 class="card__header">SailMail</h2>
    <div class="form-group">
      <label>Adresse SailMail du bateau</label>
      <%= f.text_field :sailmail_address, class: "input", placeholder: "INDICATIF@sailmail.com" %>
    </div>
  </div>

  <%= f.fields_for :relay_account do |ra| %>
    <div class="card">
      <h2 class="card__header">Compte relais (IMAP)</h2>
      <p class="txt-small txt-subtle margin-block-end">Ce compte fait le pont entre HutMail et le bateau.</p>
      <div class="form-row">
        <div class="form-group">
          <label>Serveur IMAP</label>
          <%= ra.text_field :imap_server, class: "input" %>
        </div>
        <div class="form-group">
          <label>Port</label>
          <%= ra.number_field :imap_port, class: "input", value: @vessel.relay_account.imap_port || 993 %>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Identifiant</label>
          <%= ra.text_field :imap_username, class: "input" %>
        </div>
        <div class="form-group">
          <label>Mot de passe</label>
          <%= ra.password_field :imap_password, class: "input" %>
        </div>
      </div>
      <div class="form-group">
        <label><%= ra.check_box :imap_use_ssl %> Utiliser SSL</label>
      </div>
    </div>

    <div class="card">
      <h2 class="card__header">Compte relais (SMTP)</h2>
      <div class="form-row">
        <div class="form-group">
          <label>Serveur SMTP</label>
          <%= ra.text_field :smtp_server, class: "input" %>
        </div>
        <div class="form-group">
          <label>Port</label>
          <%= ra.number_field :smtp_port, class: "input", value: @vessel.relay_account.smtp_port || 587 %>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Identifiant</label>
          <%= ra.text_field :smtp_username, class: "input" %>
        </div>
        <div class="form-group">
          <label>Mot de passe</label>
          <%= ra.password_field :smtp_password, class: "input" %>
        </div>
      </div>
      <div class="form-group">
        <label><%= ra.check_box :smtp_use_starttls %> Utiliser STARTTLS</label>
      </div>
    </div>
  <% end %>

  <div class="card">
    <h2 class="card__header">Budget radio</h2>
    <div class="form-row">
      <div class="form-group">
        <label>Budget quotidien (Ko)</label>
        <%= f.number_field :daily_budget_kb, class: "input", min: 1 %>
      </div>
      <div class="form-group">
        <label>Ratio bundle (%)</label>
        <%= f.number_field :bundle_ratio, class: "input", min: 1, max: 100 %>
        <div class="txt-x-small txt-subtle">
          <%= @vessel.bundle_ratio %> % pour les messages, <%= 100 - @vessel.bundle_ratio %> % pour le screener
        </div>
      </div>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit "Enregistrer", class: "btn btn--link" %>
  </div>
<% end %>
