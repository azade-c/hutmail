<% breadcrumbs ["Bateaux", vessels_path], [@vessel.name, vessel_path(@vessel)], ["Réglages"] %>

<div class="page-header">
  <h1>Réglages</h1>
</div>

<%= form_with(model: @vessel, url: vessel_settings_path(@vessel)) do |f| %>
  <% if @vessel.errors.any? %>
    <div class="card card--error">
      <div class="card__header txt-negative">Erreurs</div>
      <ul>
        <% @vessel.errors.full_messages.each do |msg| %>
          <li class="txt-small"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card">
    <h2 class="card__header">Bateau</h2>
    <div class="form-row">
      <div class="form-group">
        <label>Nom du bateau</label>
        <%= f.text_field :name, class: "input" %>
      </div>
      <div class="form-group">
        <label>Adresse SailMail</label>
        <%= f.text_field :sailmail_address, class: "input", placeholder: "INDICATIF@sailmail.com" %>
      </div>
    </div>
  </div>

  <%= f.fields_for :relay_account do |ra| %>
    <%= render "shared/relay_account_fields", f: ra %>
  <% end %>

  <div class="card">
    <h2 class="card__header">Budget radio</h2>
    <div class="form-row">
      <div class="form-group">
        <label>Budget quotidien (Ko)</label>
        <%= f.number_field :daily_budget_kb, class: "input", min: 1 %>
      </div>
      <div class="form-group">
        <label>Ratio dépêche (%)</label>
        <%= f.number_field :bundle_ratio, class: "input", min: 1, max: 100 %>
        <div class="txt-x-small txt-subtle">
          <%= @vessel.bundle_ratio %> % pour les messages, <%= 100 - @vessel.bundle_ratio %> % pour le screener
        </div>
      </div>
    </div>
  </div>

  <div class="card" data-controller="dispatch-schedule">
    <h2 class="card__header">Programmation des dépêches</h2>
    <div class="form-row">
      <div class="form-group">
        <label>Cadence</label>
        <%= f.select :dispatch_cadence,
            [["Manuel (bouton uniquement)", "manual"],
             ["Toutes les N heures", "every_hours"],
             ["Une fois par jour", "daily"]],
            {}, class: "input",
            data: { dispatch_schedule_target: "cadence", action: "change->dispatch-schedule#toggle" } %>
      </div>
      <div class="form-group" data-dispatch-schedule-target="everyHours">
        <label>Intervalle (heures)</label>
        <%= f.number_field :dispatch_every_hours, class: "input", min: 1, max: 24 %>
      </div>
      <div class="form-group" data-dispatch-schedule-target="daily">
        <label>Heure quotidienne (HH:MM)</label>
        <%= f.time_field :dispatch_daily_at, class: "input" %>
      </div>
      <div class="form-group">
        <label>Fuseau horaire</label>
        <%= f.select :dispatch_timezone, Vessel::Scheduling::COMMON_TIMEZONES, {}, class: "input" %>
      </div>
    </div>
    <% if @vessel.next_dispatch_at %>
      <div class="txt-x-small txt-subtle">
        Prochaine dépêche prévue : <%= l(@vessel.next_dispatch_at.in_time_zone(@vessel.dispatch_timezone), format: :short) %>
      </div>
    <% end %>
  </div>

  <div class="form-actions">
    <%= f.submit "Enregistrer", class: "btn btn--link" %>
  </div>
<% end %>
