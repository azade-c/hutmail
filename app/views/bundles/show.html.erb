<div class="page-header">
  <h1>
    Bundle #<%= @bundle.id %>
    <span class="badge badge--<%= @bundle.status %>"><%= @bundle.status %></span>
  </h1>
</div>

<div class="stat-grid">
  <div class="stat">
    <div class="stat__value"><%= @bundle.messages_count %></div>
    <div class="stat__label">Messages included</div>
  </div>
  <div class="stat">
    <div class="stat__value"><%= @bundle.remaining_count %></div>
    <div class="stat__label">In screener</div>
  </div>
  <div class="stat">
    <div class="stat__value"><%= Bundle.format_size(@bundle.total_stripped_size || 0) %></div>
    <div class="stat__label">Stripped size</div>
  </div>
  <div class="stat">
    <div class="stat__value"><%= Bundle.format_size(@bundle.total_raw_size || 0) %></div>
    <div class="stat__label">Raw size</div>
  </div>
</div>

<% if @bundle.error_message.present? %>
  <div class="card" style="--border-color: var(--color-negative);">
    <div class="card__header txt-negative">Error</div>
    <p class="txt-small"><%= @bundle.error_message %></p>
  </div>
<% end %>

<div class="card">
  <div class="card__header">Messages</div>
  <% if @messages.any? %>
    <ul class="message-list">
      <% @messages.each do |msg| %>
        <li class="message-item">
          <span class="message-item__code"><%= msg.hutmail_id %></span>
          <span class="badge"><%= msg.mail_account.short_code %></span>
          <span class="message-item__from"><%= msg.from_name.presence || msg.from_address %></span>
          — <%= msg.subject %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>

<% if @bundle.bundle_text.present? %>
  <div class="card" style="margin-block-start: var(--block-space);">
    <div class="card__header">Bundle text (as sent)</div>
    <div class="bundle-preview"><%= @bundle.bundle_text %></div>
  </div>
<% end %>
