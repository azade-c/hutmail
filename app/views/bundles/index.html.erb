<div class="page-header">
  <h1>Envois</h1>
</div>

<% if @bundles.any? %>
  <% @bundles.each do |bundle| %>
    <div class="card">
      <a href="<%= vessel_bundle_path(@vessel, bundle) %>">
        <div class="flex align-center justify-space-between">
          <span class="badge badge--<%= bundle.status %>"><%= bundle.status %></span>
          <span class="txt-small">
            <%= bundle.messages_count %> messages ·
            <%= Bundle.format_size(bundle.total_stripped_size || 0) %>
          </span>
        </div>
        <% if bundle.sent_at %>
          <div class="txt-x-small txt-subtle margin-block-start-half">
            Envoyé le <%= bundle.sent_at.strftime("%d %b %Y %H:%M") %>
          </div>
        <% else %>
          <div class="txt-x-small txt-subtle margin-block-start-half">
            Créé le <%= bundle.created_at.strftime("%d %b %Y %H:%M") %>
          </div>
        <% end %>
        <% if bundle.remaining_count.to_i > 0 %>
          <div class="txt-x-small txt-subtle">
            + <%= bundle.remaining_count %> dans le screener
          </div>
        <% end %>
      </a>
    </div>
  <% end %>
<% else %>
  <div class="empty-state">Aucun envoi pour l'instant.</div>
<% end %>
