<div class="auth">
  <h1 class="auth__title">🦫 HutMail</h1>
  <p class="auth__subtitle">Le facteur des marins hauturiers</p>

  <%= form_with url: session_path, class: "auth__form" do |form| %>
    <div class="form-group">
      <label for="email_address">Email</label>
      <%= form.email_field :email_address, class: "input", required: true, autofocus: true, autocomplete: "username", placeholder: "vous@exemple.com", value: params[:email_address] %>
    </div>

    <div class="form-group">
      <label for="password">Mot de passe</label>
      <%= form.password_field :password, class: "input", required: true, autocomplete: "current-password", placeholder: "Votre mot de passe", maxlength: 72 %>
    </div>

    <div class="form-actions">
      <%= form.submit "Se connecter", class: "btn btn--link auth__submit" %>
    </div>
  <% end %>

  <p class="auth__alt">Pas encore de compte ? <%= link_to "Créer un compte", new_user_path %></p>
</div>
